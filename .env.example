# Supabase
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Magic Links (any random string, used to sign JWTs)
MAGIC_LINK_SECRET=change-me-to-a-random-secret

# Email (optional — logs to console if not set)
RESEND_API_KEY=

# App URL (used for magic link URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (for Drive token refresh — same credentials as Supabase Google provider)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Polar.sh (subscription billing)
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret

# Seafile storage (file uploads for PDFs and covers)
SEAFILE_URL=https://your-seafile-instance.com
SEAFILE_TOKEN=your-api-token
SEAFILE_REPO_ID=your-library-id
